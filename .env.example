# ============================================================
# Environment Variables for Agentic Workflow Platform
# Copy this file to .env and fill in your values
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://platform:password@localhost:5432/agentic_platform
DB_PASSWORD=localpassword

# --- Auth (JWT) ---
# Generate a secure random key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-use-256-bit-random-key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- LLM Providers ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# --- Application ---
# development | production
APP_ENV=development
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# --- Frontend (build-time) ---
VITE_API_URL=http://localhost:8000
