# ============================================================
# Environment Variables for Agentic Workflow Platform
# Copy this file to .env and fill in your values
# ============================================================

# --- Database ---
# Production: keep DB_PASSWORD and DATABASE_URL secret and do not commit real values.
DATABASE_URL=postgresql+asyncpg://platform:password@localhost:5432/agentic_platform
DB_PASSWORD=localpassword
DB_PORT=5432

# --- Auth (JWT) ---
# Generate a secure random key: python -c "import secrets; print(secrets.token_hex(32))"
# Production: MUST be replaced with a strong random secret.
JWT_SECRET=change-me-in-production-use-256-bit-random-key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- LLM Providers ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# --- Application ---
# development | production
APP_ENV=development
# Comma-separated list of allowed CORS origins
# Production: replace with your real frontend origin, e.g. https://app.example.com
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
# json | text
LOG_FORMAT=json

# --- Frontend (build-time) ---
# Production: set to the public API origin if frontend and backend are not served from the same domain.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=
